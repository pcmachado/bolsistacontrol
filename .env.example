APP_NAME="ProBolsas - Portal de Gestão de Bolsas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://www.probolsas.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=probolsas
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=probolsas.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# CONFIGURAÇÕES DE E-MAIL PARA DESENVOLVIMENTO E PRODUÇÃO
# =============================================================================

# OPÇÃO 1: LOG (Padrão - recomendado para desenvolvimento)
# Os e-mails são salvos em storage/logs/laravel.log
# MAIL_MAILER=log

# OPÇÃO 2: MAILTRAP (Recomendado para desenvolvimento)
# Crie uma conta gratuita em https://mailtrap.io
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=seu_username_do_mailtrap
# MAIL_PASSWORD=sua_password_do_mailtrap
# MAIL_ENCRYPTION=null

# OPÇÃO 3: GMAIL (Para produção ou desenvolvimento avançado)
# ATENÇÃO: Use app passwords, não sua senha normal
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu_email@gmail.com
# MAIL_PASSWORD=sua_app_password
# MAIL_ENCRYPTION=tls

# OPÇÃO 4: SENDGRID (Para produção)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=sua_sendgrid_api_key
# MAIL_ENCRYPTION=tls

# OPÇÃO 5: AMAZON SES (Para produção)
# Configure via AWS Console primeiro
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=sua_aws_key
# AWS_SECRET_ACCESS_KEY=sua_aws_secret
# AWS_DEFAULT_REGION=us-east-1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
